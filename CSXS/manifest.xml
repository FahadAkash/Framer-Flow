<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="9.0"
    ExtensionBundleId="com.aigeolab.frameflow"
    ExtensionBundleName="FrameFlow"
    ExtensionBundleVersion="1.2"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <ExtensionList>
        <Extension Id="com.aigeolab.frameflow.panel" Version="1.2" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <!-- Premiere Pro. 22.0 == 2022. Bump the upper bound as needed. -->
            <Host Name="PPRO" Version="[22.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.aigeolab.frameflow.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./client/index.html</MainPath>
                    <ScriptPath>./host/FrameFlow.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>FrameFlow Graph Editor</Menu>
                    <Geometry>
                        <Size>
                            <Height>640</Height>
                            <Width>640</Width>
                        </Size>
                        <MinSize>
                            <Height>480</Height>
                            <Width>360</Width>
                        </MinSize>
                        <MaxSize>
                            <Height>2000</Height>
                            <Width>2000</Width>
                        </MaxSize>
                    </Geometry>
                    <Icons>
                        <Icon Type="Normal">./client/assets/icon-normal.png</Icon>
                        <Icon Type="RollOver">./client/assets/icon-rollover.png</Icon>
                    </Icons>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
